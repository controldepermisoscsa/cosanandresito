# ================================================================
# Protección de archivos sensibles
# ================================================================

# Bloquear acceso directo a config.php
<Files "config.php">
    Require all denied
</Files>

# Bloquear archivos .sql y .log
<FilesMatch "\.(sql|log)$">
    Require all denied
</FilesMatch>

# Bloquear archivos de diagnóstico, prueba y código obsoleto
<FilesMatch "^(test_conexion\.php|test_conexion_pg\.php|diagnostico_bd\.php|auth\.php|probar_correo\.php|verificar_enum\.php|verificar_asignaciones\.php)$">
    Require all denied
</FilesMatch>

# Bloquear acceso a la carpeta vendor
RewriteEngine On
RewriteRule ^vendor(/.*)?$ - [F,L]

# Evitar listado de archivos en carpetas
Options -Indexes

# Encabezados de seguridad HTTP
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
